{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information for library visitors.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "name": { "type": "string", "description": "Full name" },
        "college": { "type": "string", "description": "College or department" },
        "studentId": { "type": "string", "description": "Student ID number" },
        "isBlocked": { "type": "boolean", "description": "Whether the user is blocked from the library" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" }
      },
      "required": ["uid", "email", "name", "college", "isBlocked"]
    },
    "VisitLog": {
      "title": "Visit Log",
      "description": "Log entry for a library visit.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User UID" },
        "userName": { "type": "string", "description": "User name" },
        "college": { "type": "string", "description": "User college" },
        "reason": { "type": "string", "description": "Reason for visit" },
        "timestamp": { "type": "object", "description": "Entry timestamp" },
        "exitTimestamp": { "type": "object", "description": "Exit timestamp" }
      },
      "required": ["uid", "userName", "college", "reason", "timestamp"]
    },
    "LibraryStats": {
      "title": "Library Stats",
      "description": "Real-time statistics for the library.",
      "type": "object",
      "properties": {
        "occupancy": { "type": "integer", "description": "Current number of people in the library" }
      },
      "required": ["occupancy"]
    },
    "AppNotification": {
      "title": "App Notification",
      "description": "Notification for users and officers.",
      "type": "object",
      "properties": {
        "recipientUid": { "type": "string", "description": "UID of the notification recipient" },
        "title": { "type": "string", "description": "Notification title" },
        "message": { "type": "string", "description": "Notification message" },
        "type": { "type": "string", "enum": ["info", "success", "warning", "error"], "description": "Notification type" },
        "timestamp": { "type": "object", "description": "Timestamp" },
        "isRead": { "type": "boolean", "description": "Whether the notification has been read" }
      },
      "required": ["recipientUid", "title", "message", "type", "timestamp", "isRead"]
    },
    "SystemActivity": {
      "title": "System Activity",
      "description": "A record of a system-wide activity.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["entry", "exit", "add_user", "delete_user", "block_user", "unblock_user", "edit_user", "add_update", "edit_update", "delete_update"] },
        "actorId": { "type": "string" },
        "actorName": { "type": "string" },
        "targetId": { "type": "string" },
        "targetName": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "object" }
      },
      "required": ["type", "actorId", "actorName", "timestamp"]
    },
    "LibraryUpdate": {
      "title": "Library Update",
      "description": "An announcement or update from the library.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "object" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] }
      },
      "required": ["title", "content", "timestamp", "priority"]
    }
  },
  "firestore": {
    "users/{uid}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "visitLogs/{logId}": {
      "schema": "VisitLog",
      "description": "Library visit logs"
    },
    "stats/library": {
      "schema": "LibraryStats",
      "description": "Library occupancy stats"
    },
    "notifications/{notificationId}": {
      "schema": "AppNotification",
      "description": "App notifications"
    },
    "system_activities/{activityId}": {
      "schema": "SystemActivity",
      "description": "Global audit log of system actions"
    },
    "library_updates/{updateId}": {
      "schema": "LibraryUpdate",
      "description": "Library announcements and updates"
    }
  }
}
